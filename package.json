{
  "name": "lwg-tournament-bot",
  "version": "1.0.0",
  "description": "LittleWarGame automated tournament manager",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "install-browsers": "npx playwright install chromium",
    "dist:win":   "electron-builder --win",
    "dist:mac":   "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all":   "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "playwright": "^1.44.0",
    "express": "^4.19.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lwg.tournamentbot",
    "productName": "LWG Tournament Bot",
    "copyright": "MIT",
    "files": [
      "src/**/*",
      "dashboard/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/playwright/.local-browsers/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/playwright/.local-browsers",
        "to":   "playwright-browsers",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
